  songs                                   songs     @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([song_id], map: "idx_piracy_reports_song")
  @@index([status], map: "idx_piracy_reports_status")
}

model platform_settings {
  id         String   @id @default(uuid()) @db.Char(36)
  key        String   @unique
  value      Json
  updated_at DateTime @default(now()) 
  updated_by String?  @db.Char(36)
  users      users?   @relation(fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model pricing_zone_countries {
  id            String        @id @default(uuid()) @db.Char(36)
  country_code  String        @unique @db.Char(2)
  country_name  String
  zone_id       String        @db.Char(36)
  currency_code String        @db.Char(3)
  is_active     Boolean?      @default(true)
  created_at    DateTime?     @default(now()) 
  pricing_zones pricing_zones @relation(fields: [zone_id], references: [id], onUpdate: NoAction)

  @@index([country_code], map: "idx_pricing_zone_countries_country_code")
  @@index([zone_id], map: "idx_pricing_zone_countries_zone_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pricing_zones {
  id                     String                   @id @default(uuid()) @db.Char(36)
  zone_code              String                   @unique
  zone_name              String
  multiplier             Decimal                  @default(1.0) @db.Decimal
  is_active              Boolean?                 @default(true)
  description            String?
  created_at             DateTime?                @default(now()) 
  updated_at             DateTime?                @default(now()) 
  checkout_sessions      checkout_sessions[]
  pricing_zone_countries pricing_zone_countries[]
}

model profiles {
  id                                                             String                       @id @db.Char(36)
  email                                                          String
  full_name                                                      String?
  avatar_url                                                     String?
  bio                                                            String?
  website                                                        String?
  social_links                                                   Json?                        @default("{}")
  is_verified                                                    Boolean?                     @default(false)
  created_at                                                     DateTime                     @default(now()) 
  updated_at                                                     DateTime                     @default(now()) 
  account_status                                                 String?                      @default("active")
  upload_limit                                                   Int?                         @default(50)
  fraud_flags                                                    Json?                        @default("[]")
  kyc_status                                                     String?                      @default("pending")
  kyc_documents                                                  Json?                        @default("[]")
  suspended_at                                                   DateTime?                    
  suspension_reason                                              String?
  dynamic_pricing_enabled                                        Boolean                      @default(true)
  username                                                       String?
  role                                                           String?
