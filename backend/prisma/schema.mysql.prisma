  license_tiers                             license_tiers      @relation(fields: [license_tier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_transactions_seller_idTousers       users              @relation("transactions_seller_idTousers", fields: [seller_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles_transactions_seller_idToprofiles profiles           @relation("transactions_seller_idToprofiles", fields: [seller_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_seller_id_profiles_fkey")
  songs                                     songs              @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([buyer_id], map: "idx_transactions_buyer")
  @@index([buyer_id], map: "idx_transactions_buyer_id")
  @@index([created_at], map: "idx_transactions_created_at")
  @@index([payment_status], map: "idx_transactions_payment_status")
  @@index([seller_id], map: "idx_transactions_seller")
  @@index([seller_id], map: "idx_transactions_seller_id")
}

model user_roles {
  id         String   @id @default(uuid()) @db.Char(36)
  user_id    String   @db.Char(36)
  role       app_role @default(buyer)
  created_at DateTime @default(now()) 
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, role])
}

model users {
  id                                                          String                @id @default(uuid()) @db.Char(36)
  email                                                       String?
  password_hash                                               String?
  activity_logs                                               activity_logs[]
  audio_sessions                                              audio_sessions[]
  audio_watermarks                                            audio_watermarks[]
  cart_items                                                  cart_items[]
  disputes_disputes_againstTousers                            disputes[]            @relation("disputes_againstTousers")
  disputes_disputes_raised_byTousers                          disputes[]            @relation("disputes_raised_byTousers")
  disputes_disputes_resolved_byTousers                        disputes[]            @relation("disputes_resolved_byTousers")
  piracy_reports_piracy_reports_created_byTousers             piracy_reports[]      @relation("piracy_reports_created_byTousers")
  piracy_reports_piracy_reports_resolved_byTousers            piracy_reports[]      @relation("piracy_reports_resolved_byTousers")
  platform_settings                                           platform_settings[]
  profiles                                                    profiles?
  seller_wallets                                              seller_wallets?
  songs                                                       songs[]
  transactions_transactions_buyer_idTousers                   transactions[]        @relation("transactions_buyer_idTousers")
  transactions_transactions_seller_idTousers                  transactions[]        @relation("transactions_seller_idTousers")
  user_roles                                                  user_roles[]
  withdrawal_requests_withdrawal_requests_processed_byTousers withdrawal_requests[] @relation("withdrawal_requests_processed_byTousers")
  withdrawal_requests_withdrawal_requests_user_idTousers      withdrawal_requests[] @relation("withdrawal_requests_user_idTousers")
}

model withdrawal_requests {
  id                                            String             @id @default(uuid()) @db.Char(36)
  user_id                                       String             @db.Char(36)
  amount                                        Decimal            @db.Decimal(10, 2)
  status                                        withdrawal_status? @default(pending)
  payout_method                                 String?
  payout_details                                Json?
  processed_at                                  DateTime?          
  processed_by                                  String?            @db.Char(36)
  notes                                         String?
  created_at                                    DateTime           @default(now()) 
  cashfree_transfer_id                          String?
  cashfree_status                               String?
  cashfree_status_code                          String?
  payment_reference                             String?
  failure_reason                                String?
  retries                                       Int?               @default(0)
  users_withdrawal_requests_processed_byTousers users?             @relation("withdrawal_requests_processed_byTousers", fields: [processed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_withdrawal_requests_user_idTousers      users              @relation("withdrawal_requests_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles                                      profiles           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "withdrawal_requests_user_id_profiles_fkey")
}

enum app_role {
  admin
  seller
  buyer
}

enum content_status {
  draft
  published
  scheduled
  archived
}

enum content_type {
  page
  post
}

enum dispute_status {
  open
  in_review
  resolved
  closed
}

enum license_type {
  personal
  youtube
  commercial
  film
  exclusive
}

enum payout_verification_status {
  not_added
  pending
  verified
  rejected
}

enum song_status {
  pending
  approved
  rejected
}

enum withdrawal_status {
  pending
  approved
  processed
  rejected
}
