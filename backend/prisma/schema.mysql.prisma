generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activity_logs {
  id          String    @id @default(uuid()) @db.Char(36)
  user_id     String?   @db.Char(36)
  action      String
  entity_type String
  entity_id   String?   @db.Char(36)
  metadata    Json?     @default("{}")
  ip_address  String?
  created_at  DateTime  @default(now()) 
  users       users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  profiles    profiles? @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "activity_logs_user_id_profiles_fkey")

  @@index([created_at(sort: Desc)], map: "idx_activity_logs_created_at")
  @@index([entity_type, entity_id], map: "idx_activity_logs_entity")
  @@index([entity_type], map: "idx_activity_logs_entity_type")
  @@index([user_id], map: "idx_activity_logs_user")
  @@index([user_id], map: "idx_activity_logs_user_id")
}

model admin_bug_reports {
  id                                               String              @id @default(uuid()) @db.Char(36)
  title                                            String
  description                                      String
  affected_section                                 String
  severity                                         String              @default("medium")
  status                                           String              @default("open")
  reporter_id                                      String?             @db.Char(36)
  assignee_id                                      String?             @db.Char(36)
  screenshots                                      Json?               @default("[]")
  logs                                             Json?               @default("[]")
  internal_notes                                   Json?               @default("[]")
  resolution_notes                                 String?
  resolved_at                                      DateTime?           
  created_at                                       DateTime?           @default(now()) 
  updated_at                                       DateTime?           @default(now()) 
  profiles_admin_bug_reports_assignee_idToprofiles profiles?           @relation("admin_bug_reports_assignee_idToprofiles", fields: [assignee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_admin_bug_reports_reporter_idToprofiles profiles?           @relation("admin_bug_reports_reporter_idToprofiles", fields: [reporter_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  system_error_logs                                system_error_logs[]
}

model audio_sessions {
  id                 String    @id @default(uuid()) @db.Char(36)
  user_id            String?   @db.Char(36)
  song_id            String?   @db.Char(36)
  session_token      String    @unique
  ip_address         String?
  user_agent         String?
  device_fingerprint String?
  started_at         DateTime? @default(now()) 
  last_access        DateTime? @default(now()) 
  play_count         Int?      @default(0)
  is_valid           Boolean?  @default(true)
  expires_at         DateTime  
  created_at         DateTime? @default(now()) 
  songs              songs?    @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_audio_sessions_expires")
  @@index([song_id], map: "idx_audio_sessions_song_id")
  @@index([session_token], map: "idx_audio_sessions_token")
  @@index([user_id], map: "idx_audio_sessions_user_id")
}

model audio_watermarks {
  id             String        @id @default(uuid()) @db.Char(36)
  transaction_id String?       @db.Char(36)
  buyer_id       String        @db.Char(36)
  song_id        String        @db.Char(36)
  watermark_code String        @unique
  created_at     DateTime?     @default(now()) 
  users          users         @relation(fields: [buyer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  songs          songs         @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions   transactions? @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([buyer_id], map: "idx_audio_watermarks_buyer")
  @@index([watermark_code], map: "idx_audio_watermarks_code")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model buyer_carts {
  id         String    @id @default(uuid()) @db.Char(36)
  buyer_id   String    @db.Char(36)
  status     String?   @default("active")
  created_at DateTime? @default(now()) 
  updated_at DateTime? @default(now()) 
  expires_at DateTime?  

  @@unique([buyer_id, status])
}

model cart_items {
  id                  String        @id @default(uuid()) @db.Char(36)
  user_id             String        @db.Char(36)
  song_id             String        @db.Char(36)
  license_tier_id     String        @db.Char(36)
  created_at          DateTime      @default(now()) 
  seller_id           String?       @db.Char(36)
  base_price          Decimal       @default(0) @db.Decimal
  platform_commission Decimal       @default(0) @db.Decimal
  final_price         Decimal       @default(0) @db.Decimal
  is_exclusive        Boolean?      @default(false)
  updated_at          DateTime?     @default(now()) 
  license_tiers       license_tiers @relation(fields: [license_tier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  songs               songs         @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, song_id, license_tier_id])
  @@unique([user_id, song_id], map: "cart_items_user_song_unique")
  @@index([song_id], map: "idx_cart_items_song_id")
  @@index([user_id], map: "idx_cart_items_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chat_logs {
  id         String   @id @default(uuid()) @db.Char(36)
  user_id    String?  @db.Char(36)
  session_id String
  role       String
  content    String
  created_at DateTime @default(now()) 
  source     String?  @default("ai")
}

model chat_response_cache {
  id            String   @id @default(uuid()) @db.Char(36)
  question_hash String   @unique
  question      String
  response      String
  source        String   @default("ai")
  created_at    DateTime @default(now()) 
  expires_at    DateTime  
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model checkout_sessions {
  id                          String         @id @default(uuid()) @db.Char(36)
  buyer_id                    String         @db.Char(36)
  cart_snapshot               Json
  subtotal                    Decimal        @db.Decimal
  platform_fee                Decimal        @db.Decimal
  tax_amount                  Decimal?       @default(0) @db.Decimal
  total_amount                Decimal        @db.Decimal
  currency                    String?        @default("INR")
  status                      String?        @default("pending")
  cashfree_order_id           String?
  cashfree_payment_session_id String?
  acknowledgment_accepted     Boolean?       @default(false)
  acknowledgment_timestamp    DateTime?      
  ip_address                  String?
  user_agent                  String?
  created_at                  DateTime?      @default(now()) 
  expires_at                  DateTime?       
  completed_at                DateTime?      
  buyer_country_code          String?        @db.Char(2)
  buyer_currency_code         String?        @default("INR") @db.Char(3)
  exchange_rate_used          Decimal?       @default(1) @db.Decimal
  pricing_zone_id             String?        @db.Char(36)
  platform_fee_buyer          Decimal?       @default(0) @db.Decimal
  platform_fee_seller         Decimal?       @default(0) @db.Decimal
  promo_code_id               String?        @db.Char(36)
  promo_discount              Decimal?       @default(0) @db.Decimal
  pricing_zones               pricing_zones? @relation(fields: [pricing_zone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  promo_codes                 promo_codes?   @relation(fields: [promo_code_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders                      orders[]
}

model cms_categories {
  id         String    @id @default(uuid()) @db.Char(36)
  name       String    @unique
  slug       String    @unique
  created_at DateTime? @default(now()) 
}

model cms_content {
  id              String         @id @default(uuid()) @db.Char(36)
  type            content_type   @default(page)
  title           String
  slug            String         @unique(map: "cms_content_slug_unique")
  excerpt         String?
  content_json    Json           @default("{}")
  content_html    String?
  featured_image  String?
  author_id       String?        @db.Char(36)
  status          content_status @default(draft)
  published_at    DateTime?      
  scheduled_at    DateTime?      
  seo_title       String?
  seo_description String?
  seo_keywords    Json
  canonical_url   String?
  og_image        String?
  og_title        String?
  og_description  String?
  no_index        Boolean?       @default(false)
  view_count      Int?           @default(0)
  created_at      DateTime?      @default(now()) 
  updated_at      DateTime?      @default(now()) 
  profiles        profiles?      @relation(fields: [author_id], references: [id], onUpdate: NoAction)

  @@index([author_id], map: "idx_cms_content_author")
  @@index([published_at(sort: Desc)], map: "idx_cms_content_published_at")
  @@index([slug], map: "idx_cms_content_slug")
  @@index([status], map: "idx_cms_content_status")
  @@index([type], map: "idx_cms_content_type")
  @@index([type, status], map: "idx_cms_content_type_status")
}

model cms_media {
  id           String    @id @default(uuid()) @db.Char(36)
  file_name    String
  file_type    String
  file_size    Int
  storage_path String
  public_url   String
  alt_text     String?
  caption      String?
  uploaded_by  String?   @db.Char(36)
  created_at   DateTime? @default(now()) 
  profiles     profiles? @relation(fields: [uploaded_by], references: [id], onUpdate: NoAction)
}

model content_fingerprints {
  id                                                String    @id @default(uuid()) @db.Char(36)
  song_id                                           String?   @db.Char(36)
  audio_file_hash                                   String?
  audio_duration_ms                                 Int?
  lyrics_hash                                       String?
  lyrics_word_count                                 Int?
  copyright_check_status                            String?   @default("pending")
  plagiarism_check_status                           String?   @default("pending")
  audio_match_confidence                            Decimal?  @db.Decimal(5, 2)
  audio_match_source                                String?
  lyrics_similarity_score                           Decimal?  @db.Decimal(5, 2)
  similar_song_id                                   String?   @db.Char(36)
  checked_at                                        DateTime? 
  reviewed_by                                       String?   @db.Char(36)
  reviewed_at                                       DateTime? 
  review_notes                                      String?
  created_at                                        DateTime? @default(now()) 
  profiles                                          profiles? @relation(fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  songs_content_fingerprints_similar_song_idTosongs songs?    @relation("content_fingerprints_similar_song_idTosongs", fields: [similar_song_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  songs_content_fingerprints_song_idTosongs         songs?    @relation("content_fingerprints_song_idTosongs", fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([audio_file_hash], map: "idx_content_fingerprints_audio_hash")
  @@index([lyrics_hash], map: "idx_content_fingerprints_lyrics_hash")
  @@index([song_id], map: "idx_content_fingerprints_song")
  @@index([copyright_check_status], map: "idx_content_fingerprints_status")
}

model content_review_queue {
  id                                                String    @id @default(uuid()) @db.Char(36)
  song_id                                           String?   @db.Char(36)
  queue_type                                        String
  priority                                          Int?      @default(5)
  status                                            String?   @default("pending")
  detection_type                                    String?
  confidence_score                                  Decimal?  @db.Decimal(5, 2)
  matched_content                                   String?
  matched_song_id                                   String?   @db.Char(36)
  resolved_by                                       String?   @db.Char(36)
  resolved_at                                       DateTime? 
  resolution                                        String?
  resolution_notes                                  String?
  created_at                                        DateTime? @default(now()) 
  songs_content_review_queue_matched_song_idTosongs songs?    @relation("content_review_queue_matched_song_idTosongs", fields: [matched_song_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles                                          profiles? @relation(fields: [resolved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  songs_content_review_queue_song_idTosongs         songs?    @relation("content_review_queue_song_idTosongs", fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([song_id], map: "idx_review_queue_song")
  @@index([status, priority], map: "idx_review_queue_status")
}

model currency_exchange_rates {
  id              String    @id @default(uuid()) @db.Char(36)
  currency_code   String    @unique @db.Char(3)
  currency_name   String
  currency_symbol String
  rate_from_inr   Decimal   @db.Decimal
  last_updated    DateTime? @default(now()) 
  is_active       Boolean?  @default(true)
}

model disputes {
  id                                    String          @id @default(uuid()) @db.Char(36)
  transaction_id                        String          @db.Char(36)
  raised_by                             String          @db.Char(36)
  against                               String          @db.Char(36)
  reason                                String
  description                           String?
  status                                dispute_status? @default(open)
  resolution                            String?
  resolved_by                           String?         @db.Char(36)
  resolved_at                           DateTime?       
  created_at                            DateTime        @default(now()) 
  users_disputes_againstTousers         users           @relation("disputes_againstTousers", fields: [against], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_disputes_againstToprofiles   profiles        @relation("disputes_againstToprofiles", fields: [against], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "disputes_against_profiles_fkey")
  users_disputes_raised_byTousers       users           @relation("disputes_raised_byTousers", fields: [raised_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_disputes_raised_byToprofiles profiles        @relation("disputes_raised_byToprofiles", fields: [raised_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "disputes_raised_by_profiles_fkey")
  users_disputes_resolved_byTousers     users?          @relation("disputes_resolved_byTousers", fields: [resolved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions                          transactions    @relation(fields: [transaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model exclusive_reservations {
  id              String         @id @default(uuid()) @db.Char(36)
  song_id         String         @db.Char(36)
  buyer_id        String         @db.Char(36)
  license_tier_id String?        @db.Char(36)
  status          String?        @default("active")
  reserved_at     DateTime?      @default(now()) 
  expires_at      DateTime       
  released_at     DateTime?      
  released_reason String?
  license_tiers   license_tiers? @relation(fields: [license_tier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  songs           songs          @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model faq {
  id         String   @id @default(uuid()) @db.Char(36)
  question   String
  answer     String
  keywords   Json @default("[]")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) 
}

model favorites {
  id         String   @id @default(uuid()) @db.Char(36)
  user_id    String   @db.Char(36)
  song_id    String   @db.Char(36)
  created_at DateTime @default(now()) 
  songs      songs    @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, song_id])
  @@index([song_id], map: "idx_favorites_song_id")
  @@index([user_id], map: "idx_favorites_user_id")
}

model genres {
  id         String   @id @default(uuid()) @db.Char(36)
  name       String   @unique
  created_at DateTime @default(now()) 
  songs      songs[]
}

model knowledge_base {
  id         String   @id @default(uuid()) @db.Char(36)
  title      String
  content    String
  tags       Json @default("[]")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) 
}

model license_rights_labels {
  id            String    @id @default(uuid()) @db.Char(36)
  right_key     String    @unique
  display_name  String
  tooltip       String?
  display_order Int
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) 
}

model license_templates {
  id                     String       @id @default(uuid()) @db.Char(36)
  license_type           license_type
  version                Int          @default(1)
  is_active              Boolean?     @default(true)
  template_name          String
  legal_clauses          Json         @default("{}")
  permitted_uses         Json @default("[]")
  prohibited_uses        Json @default("[]")
  ownership_clause       String
  warranty_disclaimer    String
  indemnification_clause String
  termination_conditions String
  governing_law          String?      @default("Laws of India")
  platform_disclaimer    String
  created_at             DateTime?    @default(now()) 
  updated_at             DateTime?    @default(now()) 
  created_by             String?      @db.Char(36)
  profiles               profiles?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([license_type, version])
  @@index([license_type, is_active], map: "idx_license_templates_type_active")
}

model license_tier_definitions {
  id            String    @id @default(uuid()) @db.Char(36)
  tier_key      String    @unique
  name          String
  display_order Int
  description   String?
  rights        Json      @default("{}")
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) 
  updated_at    DateTime? @default(now()) 
}

model license_tiers {
  id                     String                   @id @default(uuid()) @db.Char(36)
  song_id                String                   @db.Char(36)
  license_type           license_type
  price                  Decimal                  @db.Decimal(10, 2)
  description            String?
  terms                  String?
  is_available           Boolean?                 @default(true)
  max_sales              Int?
  current_sales          Int?                     @default(0)
  created_at             DateTime                 @default(now()) 
  cart_items             cart_items[]
  exclusive_reservations exclusive_reservations[]
  songs                  songs                    @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions           transactions[]

  @@unique([song_id, license_type])
  @@index([song_id], map: "idx_license_tiers_song")
  @@index([song_id], map: "idx_license_tiers_song_id")
}

model moods {
  id         String   @id @default(uuid()) @db.Char(36)
  name       String   @unique
  created_at DateTime @default(now()) 
  songs      songs[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id                  String              @id @default(uuid()) @db.Char(36)
  order_number        String              @unique
  buyer_id            String              @db.Char(36)
  checkout_session_id String?             @db.Char(36)
  subtotal            Decimal             @db.Decimal
  platform_fee        Decimal             @db.Decimal
  tax_amount          Decimal?            @default(0) @db.Decimal
  total_amount        Decimal             @db.Decimal
  currency            String?             @default("INR")
  payment_status      String?             @default("pending")
  payment_method      String?
  cashfree_order_id   String?
  cashfree_payment_id String?
  fulfillment_status  String?             @default("pending")
